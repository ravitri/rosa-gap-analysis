# Gap Analysis - Generated Files

# Temporary files (scripts create temp dirs but clean them up)
*.tmp
*.log
.tmp/

# Python cache
__pycache__/
*.pyc
*.pyo

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Reports
reports/
.agentready

# CI artifacts (only used if user explicitly specifies --work-dir ./ci/artifacts)
ci/artifacts/

# Claude local settings (user-specific)
.claude/settings.local.json

# GitHub PR configuration (contains bot settings)
.github-pr-config

# === Additional patterns for agent-readiness ===
# IDE and editor files
.idea/
.vscode/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db
